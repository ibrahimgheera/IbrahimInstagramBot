/help - Help menu\
\
Tell me what you need!\
"""\
    bot.reply_to(message, welcome)\
\
\
@bot.message_handler(commands=['caption'])\
def caption_command(message):\
    """\
    When you type /caption, bot asks for photo description\
    """\
    msg = bot.reply_to(message, "\uc0\u55357 \u56568  Describe your photo:\\n\\nExample: 'Heavy deadlift at gym, 180kg PR'")\
    \
    # Wait for next message\
    bot.register_next_step_handler(msg, generate_caption_from_description)\
\
\
def generate_caption_from_description(message):\
    """\
    Takes your description and generates caption\
    """\
    photo_description = message.text\
    \
    # Show we're thinking\
    bot.send_chat_action(message.chat.id, 'typing')\
    \
    # Generate the caption\
    caption = generate_caption(photo_description, content_type="fitness")\
    \
    # Send the caption back to you\
    response = f"""\
\uc0\u10024  GENERATED CAPTION:\
\
\{caption\}\
\
---\
\
Options:\
/post - Post this now\
/edit - Edit the caption\
/schedule - Schedule for specific time\
/discard - Delete\
"""\
    \
    bot.send_message(message.chat.id, response)\
\
\
