# Handle all other text messages\
@bot.message_handler(func=lambda message: True)\
def handle_messages(message):\
    """\
    Handles any message that doesn't match a command\
    """\
    \
    text = message.text.lower()\
    \
    if "hello" in text or "hi" in text:\
        bot.reply_to(message, "\uc0\u55357 \u56395  Hey Ibrahim! Type /caption to generate Instagram captions, or /help for more options.")\
    \
    elif "status" in text:\
        bot.send_message(message.chat.id, "\uc0\u10003  Bot is running perfectly!")\
    \
    else:\
        bot.reply_to(message, "I didn't understand that. Type /help to see what I can do!")\
\
